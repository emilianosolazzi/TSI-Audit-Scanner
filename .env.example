# Audit Service Environment Configuration

# Environment: development, staging, production
AUDIT_ENV=development
AUDIT_DEBUG=true

# Server
AUDIT_HOST=0.0.0.0
AUDIT_PORT=8080

# Etherscan API Key (required)
ETHERSCAN_API_KEY=8HVN717M5MCN4X7EY5XU8YXD4GE8DCPBCA

# Database
DATABASE_URL=sqlite:///audit_service.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:pass@localhost:5432/audit_service

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=generate-a-secure-random-string-here
JWT_EXPIRY_HOURS=24

# Caching
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO

# Scanner — repo scanning & scheduling
GITHUB_TOKEN=                          # Optional: for private repos
SCANNER_WORKSPACE=./scanner_workspace  # Where repos are cloned
SCANNER_DB=scan_history.db             # SQLite scan history
SCANNER_RESULTS=scan_results           # Directory for JSON results
LOG_FILE=audit_service.log

# Stripe (for payments - future)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
